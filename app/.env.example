# Config
PROJECT_NAME=launchpad

# Database
DATABASE_HOST=localhost
DATABASE_NAME=postgres
DATABASE_USER=postgres.launchpad
DATABASE_PASSWORD=your-super-secret-and-long-postgres-password
DATABASE_PORT=5432

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-07-01-preview

# Anthropic
ANTHROPIC_API_KEY=

# Gemini
GEMINI_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Bedrock
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=

# Claude Code — SDK mode (subscription)
CLAUDE_CODE_BIN=
CLAUDE_CODE_CWD=
CLAUDE_CODE_PERMISSION_MODE=bypassPermissions
CLAUDE_CODE_SDK_TIMEOUT_SECONDS=180

# Claude Code — session mode (bastion)
BASTION_BIN=bastion
CLAUDE_CODE_TMUX_SESSION=orchestrator-claude
CLAUDE_CODE_WORKDIR=
CLAUDE_CODE_IO_DIR=
CLAUDE_CODE_SESSION_TIMEOUT_SECONDS=180

# API security (required for public exposure)
# Strong random secret — used by POST /events/; set to a long random value before deploying.
ORCHESTRATION_API_KEY=
# Comma-separated list of allowed CORS origins.  Default: https://learn-agentic-ai.com
ALLOWED_ORIGINS=https://learn-agentic-ai.com

# Telegram bot (required when running integrations/telegram/bot.py)
# Token issued by @BotFather — required.
TELEGRAM_BOT_TOKEN=
# Base URL of the orchestration API as seen from the bot process.
# Use http://localhost:8080 locally; http://api:8080 inside Docker Compose.
ORCHESTRATION_API_BASE_URL=http://localhost:8080
# Comma-separated list of Telegram chat IDs the bot accepts commands from.  Optional but recommended.
TELEGRAM_ALLOWED_CHAT_IDS=
# Cloudflare Access service-token headers — only required when the bot calls the API via
# the public hostname (api.learn-agentic-ai.com).  Leave empty for internal/local use.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=