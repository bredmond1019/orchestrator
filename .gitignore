# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover

# Translations
*.mo
*.pot

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# DotEnv configuration
.env
.env.local
.env.*.local

# Database
*.db
*.rdb

# Generated content digest (runtime output of content_pipeline StorageNode)
_digest/

# Pycharm
.idea

# VS Code
.vscode/
*.code-workspace

# Spyder
.spyproject/

# Jupyter NB Checkpoints
.ipynb_checkpoints/

# Mac OS-specific storage files
.DS_Store

# vim
*.swp
*.swo

# Mypy cache
.mypy_cache/

# Virtual environment
.venv/

# Alembic migrations
app/alembic/versions/*
!app/alembic/versions/.gitkeep
# Foundational migrations that must be version-controlled
!app/alembic/versions/*_enable_pgvector_extension.py
!app/alembic/versions/*_create_learning_artifacts_table.py
!app/alembic/versions/*_create_events_table.py
!app/alembic/versions/*_create_brain_documents_table.py
!app/alembic/versions/*_merge_brain_documents_and_events_heads.py

# Playground
playground/*.png

# Git worktrees (SDLC isolation)
trees/

# Local dev helper scripts (machine-specific: Homebrew paths, local DB creds;
# regenerated on demand by tooling, never committed — except committed CLI tools)
/scripts/*
!/scripts/index_brain.py